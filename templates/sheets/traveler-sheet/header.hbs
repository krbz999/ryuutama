<section data-tooltip-direction="UP">
  {{#if disabled}}
  <aside class="avatar">
    <img src="{{document.img}}" alt="{{document.name}}" data-action="showPortrait">
  </aside>
  <h3 class="title nameplate dropshadow gold-border" data-tooltip-text="{{document.name}}">{{document.name}}</h3>

  {{!-- TAGS --}}
  <div class="tags">
    {{#if levelUp}}
    <a data-action="advance" class="tag {{#if levelUp.glow}} glow {{/if}}" data-tooltip-text="{{levelUp.tooltip}}" {{disabled not editable}}>
      {{levelUp.tag}}
    </a>
    {{/if}}
    {{#each tags}}
    <div class="tag {{cssClass}}" data-tooltip-text="{{tooltip}}">{{{tag}}}</div>
    {{/each}}
  </div>

  {{!-- EXP --}}
  <div class="form-group">
    <div class="form-fields">
      <resource-bar resource="system.details.exp" class="exp" id="{{rootId}}-exp"></resource-bar>
    </div>
  </div>

  {{else}}
  {{formGroup fields.name value=source.name classes="stacked"}}
  {{formGroup fields.img value=source.img classes="stacked"}}

  <hr>

  {{/if}}

  {{!-- ABILITIES --}}
  <section class="abilities">
    {{#each abilities}}
    <div class="ability" data-tooltip-text="{{label}}">
      {{#if @root.isEditable}}
      <a data-action="configure" data-config="ability" data-ability="{{ability}}">
        <i class="fa-solid fa-cog" inert></i>
      </a>
      {{else}}
      <ryuutama-icon src="{{icon}}"></ryuutama-icon>
      {{/if}}
      <span class="value">{{value.die}}</span>
    </div>
    {{/each}}
  </section>

  {{!-- ACTIONS --}}
  {{#if disabled}}
  <section class="actions">
    <a data-action="rollCheck" data-check="check" {{disabled (not isInteractive)}}>
      <i class="fa-solid fa-dice" inert></i>
      <span>{{localize "RYUUTAMA.ACTOR.rollCheck"}}</span>
    </a>
    <a data-action="rollAttack" {{disabled (not isInteractive)}}>
      <i class="fa-solid fa-dice" inert></i>
      <span>{{localize "RYUUTAMA.ACTOR.rollAttack"}}</span>
    </a>
  </section>
  {{/if}}

  {{!-- HP & MP --}}
  <section class="resources">
    <div class="stamina">
      <label>{{localize "RYUUTAMA.ACTOR.HP"}}</label>
      <div class="resource">
        <resource-bar resource="system.resources.stamina" class="stamina dropshadow {{#if this.document.system.resources.stamina.negative}} negative {{/if}}" id="{{rootId}}-stamina"></resource-bar>
        {{#unless disabled}}
        <a data-action="configure" data-config="resource" data-resource="stamina">
          <i class="fa-solid fa-cog" inert></i>
        </a>
        {{/unless}}
      </div>
    </div>
    <div class="mental">
      <label>{{localize "RYUUTAMA.ACTOR.MP"}}</label>
      <div class="resource">
        <resource-bar resource="system.resources.mental" class="mental dropshadow" id="{{rootId}}-mental"></resource-bar>
        {{#unless disabled}}
        <a data-action="configure" data-config="resource" data-resource="mental">
          <i class="fa-solid fa-cog" inert></i>
        </a>
        {{/unless}}
      </div>
    </div>
  </section>

  {{!-- STATUSES --}}
  <section class="statuses">
    {{#each statuses}}
    <div class="status" data-tooltip-text="{{tooltip}}">
      <a class="dropshadow gold-border" data-action="toggleStatus" data-status="{{status}}" {{disabled (not @root.editable)}}>
        <ryuutama-icon src="{{img}}"></ryuutama-icon>
      </a>
      <span class="value {{#if active}} nameplate active {{/if}}">{{{label}}}</span>
    </div>
    {{/each}}
  </section>
</section>
