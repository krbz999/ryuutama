<section>
  {{#if disabled}}
  <aside class="avatar">
    <img src="{{document.img}}" alt="{{document.name}}">
  </aside>
  <h3 class="title">
    <span>{{document.name}}</span>
  </h3>
  <div class="tags">
    {{#if levelUp}}
    <a data-action="advance" class="tag {{#if levelUp.glow}} glow {{/if}}" data-tooltip-text="{{levelUp.tooltip}}" {{disabled not editable}}>
      {{levelUp.tag}}
    </a>
    {{/if}}
    {{#each tags}}
    <div class="tag {{cssClass}}" data-tooltip-text="{{tooltip}}">{{{tag}}}</div>
    {{/each}}
  </div>
  <div class="form-group">
    <div class="form-fields">
      <resource-bar resource="system.details.exp" class="exp" id="{{rootId}}-exp"></resource-bar>
    </div>
  </div>
  {{else}}
  {{formGroup fields.name value=source.name classes="stacked"}}
  {{formGroup fields.img value=source.img classes="stacked"}}

  <hr>
  {{/if}}

  {{!-- HP & MP --}}
  {{> "actor-resources"}}

  {{!-- FUMBLES --}}
  <div class="icon-fields">
    <div class="icon-field">
      <ryuutama-icon src="systems/ryuutama/assets/official/icons/check/fumble.svg"></ryuutama-icon>
      <div class="form-group stacked">
        <label for="{{rootId}}-system.fumbles.value">{{systemFields.fumbles.fields.value.label}}</label>
        <div class="form-fields">
          <input type="text" name="system.fumbles.value" class="delta" value="{{ifThen disabled document.system.fumbles.value source.system.fumbles.value}}" {{disabled (not editable)}} placeholder="0" id="{{rootId}}-system.fumbles.value">
        </div>
      </div>
    </div>
  </div>
</section>
