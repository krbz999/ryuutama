<section data-tooltip-direction="UP">
  {{#if disabled}}
  <aside class="avatar">
    <img src="{{document.img}}" alt="{{document.name}}" data-action="showPortrait">
  </aside>
  <h3 class="title nameplate dropshadow gold-border" data-tooltip-text="{{document.name}}">{{document.name}}</h3>
  <div class="tags">
    {{#if levelUp}}
    <a data-action="advance" class="tag {{#if levelUp.glow}} glow {{/if}}" data-tooltip-text="{{levelUp.tooltip}}" {{disabled not editable}}>
      {{levelUp.tag}}
    </a>
    {{/if}}
    {{#each tags}}
    <div class="tag {{cssClass}}" data-tooltip-text="{{tooltip}}">{{{tag}}}</div>
    {{/each}}
  </div>
  <div class="form-group">
    <div class="form-fields">
      <resource-bar resource="system.details.exp" class="exp" id="{{rootId}}-exp"></resource-bar>
    </div>
  </div>

  {{!-- ACTIONS --}}
  <div class="actions">

    <button type="button" data-action="rollCheck" data-check="check" {{disabled (not isInteractive)}}>
      <i class="fa-solid fa-dice" inert></i>
      <span>{{localize "RYUUTAMA.ACTOR.rollCheck"}}</span>
    </button>

    <button type="button" data-action="rollAttack" {{disabled (not isInteractive)}}>
      <i class="fa-solid fa-dice" inert></i>
      <span>{{localize "RYUUTAMA.ACTOR.rollAttack"}}</span>
    </button>

  </div>

  {{else}}
  {{formGroup fields.name value=source.name classes="stacked"}}
  {{formGroup fields.img value=source.img classes="stacked"}}

  <hr>
  {{/if}}

  {{!-- HP & MP --}}
  {{> "actor-resources"}}

  {{!-- STATUSES --}}
  <section class="statuses">
    {{#each statuses}}
    <div class="status">
      <a class="dropshadow gold-border" data-action="toggleStatus" data-status="{{status}}" {{disabled (not @root.editable)}} data-tooltip-text="{{tooltip}}">
        <ryuutama-icon src="{{img}}" {{#if active}} class="active" {{/if}}></ryuutama-icon>
      </a>
      <span class="value nameplate">{{{label}}}</span>
    </div>
    {{/each}}
  </section>
</section>
