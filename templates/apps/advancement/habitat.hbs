<form>
  <fieldset>
    <legend>{{localize "RYUUTAMA.ADVANCEMENT.HABITAT.label"}}</legend>
    {{formGroup fields.choice.fields.type options=typeOptions value=advancement.choice.type rootId=rootId}}

    {{#if showTerrains}}
    {{formGroup fields.choice.fields.chosen.fields.terrain value=advancement.choice.chosen.terrain rootId=rootId classes="slim"}}
    {{/if}}

    {{#if showWeathers}}
    {{formGroup fields.choice.fields.chosen.fields.weather value=advancement.choice.chosen.weather rootId=rootId classes="slim"}}
    {{/if}}
  </fieldset>
</form>
